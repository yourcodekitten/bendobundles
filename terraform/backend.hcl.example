bucket               = "brd-prod-ue1-tfstate-store"
key                  = "terraform.tfstate"
kms_key_id           = "alias/aws/s3"
encrypt              = true
region               = "us-east-1"
use_lockfile         = true # S3-native locking (TF >= 1.10); no dynamodb_table
workspace_key_prefix = "bendobundles"
